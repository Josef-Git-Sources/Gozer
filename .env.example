# ============================================
# גוזר — משתני סביבה
# העתק קובץ זה ל-.env ומלא את הערכים
# ============================================

# --- מסד נתונים (Supabase) ---
# קבל מ: supabase.com → Settings → Database → Connection String → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# --- NextAuth ---
# הרץ: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# כתובת האפליקציה (ב-Vercel: https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Google OAuth ---
# קבל מ: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Resend (שליחת מיילים) ---
# קבל מ: resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@gozer.io"

# --- Google Search Console (אופציונלי) ---
# קבל מ: search.google.com/search-console → הוסף נכס → HTML Tag
GOOGLE_SITE_VERIFICATION=""
